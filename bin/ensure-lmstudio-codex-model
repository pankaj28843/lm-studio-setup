#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
from pathlib import Path


def main() -> None:
    script = Path(__file__).resolve()
    repo_root = script.parents[1]
    os.execvp(
        "uv",
        [
            "uv",
            "run",
            "--project",
            str(repo_root),
            "python",
            "-m",
            "lmstudio_setup.ensure_cli",
            *sys.argv[1:],
        ],
    )


if __name__ == "__main__":
    main()
